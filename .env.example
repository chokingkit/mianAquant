# ============================================
# A股量化交易选股系统 - 环境变量配置
# ============================================

# ---------- 应用基础配置 ----------
# 应用名称
APP_NAME=A股量化交易选股系统

# 调试模式 (True/False)
DEBUG=True

# ---------- 数据源配置 ----------
# 数据源类型: tushare 或 akshare
DATA_PROVIDER=tushare

# Tushare API Token (从 https://tushare.pro 注册获取)
TUSHARE_TOKEN=your_tushare_token_here

# 是否启用 AKShare (True/False)
AKSHARE_ENABLE=True

# ---------- PostgreSQL 数据库配置 ----------
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=quant_user
POSTGRES_PASSWORD=quant_password
POSTGRES_DB=quant_db

# ---------- Redis 缓存配置 ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- Qlib 配置 ----------
# Qlib 数据存储路径
QLIB_DATA_PATH=./data/qlib_data

# ---------- API 配置 ----------
# API 路由前缀
API_PREFIX=/api/v1

# CORS 允许的源 (多个用逗号分隔)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
